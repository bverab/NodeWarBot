{
  "name": "nodewarbot",
  "version": "1.0.0",
  "description": "Bot para NodeWars del juego Black Desert Online, formato OpenSource",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "register": "node src/register-commands.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration tests/smoke",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:import-json": "node scripts/migrate-json-to-sqlite.js",
    "db:export-json": "node scripts/export-sqlite-to-json.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "node-cron": "^4.2.1",
    "prisma": "^6.15.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  }
}
